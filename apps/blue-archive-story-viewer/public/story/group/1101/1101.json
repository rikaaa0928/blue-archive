      "VoiceJp": ""
    },
    {
      "GroupId": 1101,
      "SelectionGroup": 0,
      "BGMId": 0,
      "Sound": "SE_Cartoon_01",
      "Transition": 0,
      "BGName": 0,
      "BGEffect": 0,
      "PopupFileName": "",
      "ScriptKr": "",
      "TextJp": "",
      "TextCn": "",
      "TextTh": "",
      "TextTw": "",
      "TextEn": "",
      "VoiceJp": ""
    },
    {
      "GroupId": 1101,
      "SelectionGroup": 0,
      "BGMId": 0,
      "Sound": "",
      "Transition": 0,
      "BGName": 0,
      "BGEffect": 0,
      "PopupFileName": "",
      "ScriptKr": "3;이즈미;04;아, 안돼! 기다려!! #n이 피도 눈물도 없는 것들아!! 같이 가! \n#3;al\n#3;hophop",
      "TextJp": "ね、ねえ！待って！！\nちょっと、血も涙もないの！？置いていかないでー！",
      "TextCn": "等、等等我！！你们怎么这么冷血！？别丢下我呀——！",
      "TextTh": "",
      "TextTw": "",
      "TextEn": "",
      "VoiceJp": "https://r2.rikaaa0928.moe/ba-story-viewer/tts/group/1101/lines/0023.mp3",
      "TextJpVoice": "[panicked]ね、ねえ！待って！！[shouting]ちょっと、血も涙もないの！？置いていかないでー！"
    },
    {
      "GroupId": 1101,
      "SelectionGroup": 0,
      "BGMId": 0,
      "Sound": "SFX_Emoticon_Motion_Surprise",
      "Transition": 0,
      "BGName": 0,
      "BGEffect": 0,
      "PopupFileName": "",
      "ScriptKr": "3;이즈미;08;(미끄덩-) 후냐앙?!\n#3;shake\n#3;em;[?!]",
      "TextJp": "ふあっ！？（ズルッ）",
      "TextCn": "诶呀！？（打滑）",
      "TextTh": "",
      "TextTw": "",
      "TextEn": "",
      "VoiceJp": "https://r2.rikaaa0928.moe/ba-story-viewer/tts/group/1101/lines/0024.mp3",
      "TextJpVoice": "[shocked]ふあっ！？[short pause]（ズルッ）"
    },
    {
