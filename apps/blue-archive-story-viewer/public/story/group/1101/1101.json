      "ScriptKr": "#all;hide\n#na;(콰당탕-!)\n#bgshake\n#fontsize;80",
      "TextJp": "（ドサッッッ！！！）",
      "TextCn": "（扑通——！！！）",
      "TextTh": "",
      "TextTw": "",
      "TextEn": "",
