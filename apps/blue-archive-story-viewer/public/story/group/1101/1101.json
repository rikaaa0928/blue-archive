      "ScriptKr": "#place;게헨나 외곽 어딘가",
      "TextJp": "ゲヘナ・郊外某所",
      "TextCn": "格黑娜·郊外某处",
      "TextTh": "",
      "TextTw": "",
      "TextEn": "",
      "VoiceJp": "",
      "TextJpVoice": "ゲヘナ・郊外某所"
    },
